{% extends 'public/base.html.twig' %}

{% block title %}Liste des tutoriels{% endblock %}

{% block stylesheets %}

    <link rel="stylesheet" href="{{ asset('assets/css/tutorial/list/style.css') }}">

{% endblock %}


{% block body %}

    <main>
        <div class="w-75 m-auto d-flex align-items-center justify-content-between mt-5">

            <form class="d-flex col-lg-4 col m-lg-auto" action="{{ path('public_list_tutorials') }}" method="get">
                <input class="input-search text-start w-100" type="text" name="search" placeholder="Rechercher un pays"
                       value="{{ search|default('') }}">
                <button type="submit" class="button-search"><img class="w-100 h-100 img-fluid"
                                                                 src="{{ asset('assets/img_statics/forum/search.png') }}"
                                                                 alt="Image d'une loupe de recherche"></button>
            </form>


        </div>

        {% if search %}
            <h1 class="choice-country mb-5 mt-5">Résultat de recherche pour "{{ search }}"</h1>
        {% else %}
            <h1 class="choice-country mb-5 mt-5">Choisis un pays</h1>
        {% endif %}

        <section class="w-75 m-auto row justify-content-between">

            {% for tutorial in tutorials %}

                <a href="{{ path('public_show_tutorial', {'id': tutorial.id}) }}"
                   class="container-country col-lg-3 col-5 m-1 mb-5 h-100 p-0">
                    <h2 class="country-name">{{ tutorial.title }}</h2>
                    <div class="w-100 h-100 container-flag">
                        <img class="img-fluid w-100 h-100"
                             src="{{ asset('assets/img_uploads/img_tutorials/' ~ tutorial.image) }}"
                             alt="Image du tutoriel {{ tutorial.title }}">
                    </div>
                </a>

            {% endfor %}


        </section>


    </main>

{% endblock %}

