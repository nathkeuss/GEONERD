{% extends 'public/base.html.twig' %}

{% block title %}Liste des tutoriels{% endblock %}

{% block stylesheets %}

{% endblock %}


{% block body %}

    <form action="{{ path('public_list_tutorials') }}" method="get">
        <input type="text" name="search" placeholder="Rechercher un tutoriel" value="{{ search|default('') }}">
        <button type="submit">Rechercher</button>
    </form>

    {% if search %}
        <h1>Résultat de recherche pour "{{ search }}"</h1>
    {% else %}
        <h1>Liste de tous les tutoriels</h1>
    {% endif %}

    <ul>
        {% for tutorial in tutorials %}
            <li>
                <h3>Titre du tutoriel : {{ tutorial.title }}</h3>
                <div>
                    <img src="{{ asset('assets/img_uploads/img_tutorials/' ~ tutorial.image) }}" alt="Image du tutoriel {{ tutorial.title }}" style="max-height: 150px;">
                </div>
                <a href="{{ path('public_show_tutorial', {'id': tutorial.id}) }}">Afficher</a>
            </li>
        {% endfor %}
    </ul>

{% endblock %}

