{% extends 'public/base.html.twig' %}

{% block title %}Tutoriel {{ tutorial.title }}{% endblock %}

{% block stylesheets %}

{% endblock %}


{% block body %}

    <main>
        <section>
            <h1>{{ tutorial.title }}</h1>
            <img src="{{ asset('assets/img_uploads/img_tutorials/' ~ tutorial.image) }}" alt="Image du tutoriel {{ tutorial.title }}" style="max-height: 300px;">
        </section>

        <section>

            {% for tutorialPart in tutorialParts %}
                <article>
                    <img src="{{ asset('assets/img_uploads/img_tutorials/' ~ tutorialPart.image) }}" alt="Image descriptif d'un élément du tutoriel {{ tutorial.title }}" style="max-height: 150px;">
                    <p>{{ tutorialPart.content }}</p>
                </article>
            {% endfor %}
        </section>
    </main>

{% endblock %}


