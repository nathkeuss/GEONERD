{% extends 'public/base.html.twig' %}

{% block title %}Créer une discussion{% endblock %}

{% block stylesheets %}

    <link rel="stylesheet" href="{{ asset('assets/css/forum/post/create/style.css') }}">

{% endblock %}


{% block body %}

    <main>

        <section class="col-10 col-lg-6 m-auto mt-5 section-form">

            <h1 class="h1-new-discussion text-center">Créer une nouvelle discussion</h1>

            <div class="w-95 m-auto">
                {{ form_start(formForumPostView) }}
                <div class="w-75 error">
                    {{ form_widget(formForumPostView.title) }}
                    {{ form_errors(formForumPostView.title) }}
                </div>

                <div class="w-100 error">
                    {{ form_widget(formForumPostView.content) }}
                    {{ form_errors(formForumPostView.content) }}
                </div>

                <div class="w-25 error">
                    {{ form_widget(formForumPostView.image) }}
                    {{ form_errors(formForumPostView.image) }}
                </div>


                <div class="text-end">
                    {{ form_widget(formForumPostView.Publier) }}
                </div>
                {{ form_end(formForumPostView) }}
            </div>

        </section>

    </main>

{% endblock %}


