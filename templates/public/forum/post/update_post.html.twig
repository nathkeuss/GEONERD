{% extends 'public/base.html.twig' %}

{% block title %}Modifier la discussion{% endblock %}

{% block stylesheets %}

    <link rel="stylesheet" href="{{ asset('assets/css/forum/post/update/style.css') }}">

{% endblock %}


{% block body %}

    <main>

        <section class="w-50 m-auto mt-5 section-form">

            <h1 class="h1-new-discussion text-center">Modifier la discussion</h1>

            <div class="w-95 m-auto">

                {{ form_start(formForumUpdatePostView) }}
                <div class="w-75">
                    {{ form_widget(formForumUpdatePostView.title) }}
                    {{ form_errors(formForumUpdatePostView.title) }}
                </div>

                <div class="w-100">
                    {{ form_widget(formForumUpdatePostView.content) }}
                    {{ form_errors(formForumUpdatePostView.content) }}
                </div>

                <div class="w-25">
                    {{ form_widget(formForumUpdatePostView.image) }}
                    {{ form_errors(formForumUpdatePostView.image) }}
                </div>

                <div class="text-end">
                    {{ form_widget(formForumUpdatePostView.Publier) }}
                </div>
                {{ form_end(formForumUpdatePostView) }}
            </div>

        </section>

    </main>


{% endblock %}


