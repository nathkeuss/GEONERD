<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Accueil GEONERD{% endblock %}</title>
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
          rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="{{ asset('assets/css/base/style.css') }}">

    {% block stylesheets %}
    {% endblock %}

</head>
<body class="d-flex flex-column">

<header>

    <nav class="navbar navbar-expand-sm container-fluid w-95">
        <!-- Logo -->
        <a class="nav-img-logo navbar-brand m-0" href="{{ path('home') }}">
            <img class="w-100 h-100" src="{{ asset('assets/img_statics/base/logo_site.png') }}"
                 alt="Logo du site GEONERD, une planète avec des yeux et un doigt levé en mode 'actually' ">
        </a>

        <!-- Navbar content -->
        <div class="navbar-collapse">
            <ul class="navbar-nav w-100 d-flex justify-content-between align-items-center">
                <!-- Navigation links -->
                <div class="d-flex">
                    <li class="nav-item nav-responsive">
                        {% if app.request.attributes.get('_route') != 'home' %}
                            <a class="nav-a-text d-none d-lg-block" href="{{ path('home') }}">ACCUEIL</a>
                        {% endif %}
                    </li>
                    <li class="nav-item">
                        <a class="nav-a-text" href="{{ path('public_list_tutorials') }}">TUTO</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-a-text" href="{{ path('forum') }}">FORUM</a>
                    </li>
                </div>

                <!-- Connexion/Dropdown -->
                {% if app.user %}
                    <li class="nav-item">
                        <div class="nav-a-connection d-flex align-items-center text-decoration-none" id="profile-menu">
                            <div class="div-img-profile me-3">
                                <img src="{{ asset('assets/img_uploads/img_profile/' ~ app.user.profilePicture) }}"
                                     alt="Image de profil de {{ app.user.username }}"
                                     class="img-fluid rounded-circle w-100 h-100">
                            </div>
                            <span>{{ app.user.username }}</span>
                        </div>
                        <div class="custom-dropdown position-absolute ms-5" id="profile-dropdown" style="display:none;">
                            <a class="custom-dropdown-item d-flex mb-2" href="{{ path('profile', {'id': app.user.id}) }}">Mon compte</a>
                            <hr style="color: white">
                            <a class="custom-dropdown-item" href="{{ path('user_logout') }}">Déconnexion</a>
                        </div>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <a class="nav-a-connection d-flex align-items-center text-decoration-none text-light"
                           href="{{ path('public_login') }}">
                            <img src="{{ asset('assets/img_statics/base/utilisateur.png') }}"
                                 alt="Icône d'un bonhomme de connexion">
                            Connexion
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </nav>


</header>


{% block body %}{% endblock %}


<footer>

    <nav>
        <ul class="d-flex align-items-center m-0">
            <li class="footer-li"><a class="footer-a" href="{{ path('home') }}">GEONERD</a></li>
            <li class="footer-li offset-7 offset-lg-8"><a class="footer-a" href="https://discord.gg/2FYmuFb9kZ"
                                                          target="_blank"><img class="w-100 h-100"
                                                                               src="{{ asset('assets/img_statics/base/logo_discord.svg') }}"
                                                                               alt="Lien qui dirige vers le discord du site"></a>
            </li>
            <li class="footer-li"><a class="footer-a" href="https://www.youtube.com/@keuss" target="_blank"><img
                            class="w-100 h-100" src="{{ asset('assets/img_statics/base/logo_youtube.png') }}"
                            alt="Lien qui dirige vers le Youtube du créateur"></a></li>
        </ul>
    </nav>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('assets/js/base/scripts.js') }}"></script>

{% block javascripts %}
{% endblock %}
</body>
</html>
