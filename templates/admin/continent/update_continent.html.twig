{% extends 'admin/base.html.twig' %}

{% block title %}Modifier le continent{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #121212;
            color: #f1f1f1;
        }

        .form-control {
            font-size: 1.1rem;
        }

        .form-label {
            font-size: 1.2rem;
        }

        .btn {
            font-size: 1.1rem;
            padding: 0.6rem 1.2rem;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="container py-5">
        <h1 class="text-center mb-4">Modifier le continent</h1>

        <div class="card bg-dark text-light p-4 shadow-lg">
            {{ form_start(formContinentView) }}

            <div class="mb-3">
                {{ form_label(formContinentView.name) }}
                {{ form_widget(formContinentView.name) }}
                {{ form_errors(formContinentView.name) }}
            </div>

            <div class="text-center">
                {{ form_widget(formContinentView.Valider) }}
            </div>

            {{ form_end(formContinentView) }}
        </div>
    </main>
{% endblock %}
