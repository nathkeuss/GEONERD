{% extends 'admin/base.html.twig' %}

{% block title %}Créer un continent{% endblock %}

{% block stylesheets %}

{% endblock %}

{% block body %}

    <h1>Créer un continent</h1>

    {{ form_start(formContinentView) }}

    <div>
        {{ form_label(formContinentView.name, 'Nom du continent') }}
        {{ form_widget(formContinentView.name) }}
        {{ form_errors(formContinentView.name) }}
    </div>

    <div>
        {{ form_widget(formContinentView.Valider) }}
    </div>

    {{ form_end(formContinentView) }}

{% endblock %}
