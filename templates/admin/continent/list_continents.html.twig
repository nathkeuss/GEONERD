{% extends 'admin/base.html.twig' %}

{% block title %}Liste des continents{% endblock %}

{% block stylesheets %}

{% endblock %}


{% block body %}

    <form action="{{ path('list_continents') }}" method="get">
        <input type="text" name="search" placeholder="Rechercher un continent" value="{{ search|default('') }}">
        <button type="submit">Rechercher</button>
    </form>

    {% if search %}
        <h1>Résultat de recherche pour "{{ search }}"</h1>
    {% else %}
        <h1>Liste de tous les continents</h1>
    {% endif %}

    <ul>
        {% for continent in continents %}
            <li>
                <h3>Nom du continent : {{ continent.name }}</h3>
                <a href="{{ path('update_continent', {'id': continent.id}) }}">Modifier</a>
                <a href="{{ path('delete_continent', {'id': continent.id}) }}" onclick="return confirm('Êtes-vous sûr de vouloir supprimer ce continent ?')">Supprimer</a>
            </li>
        {% endfor %}
    </ul>

{% endblock %}
