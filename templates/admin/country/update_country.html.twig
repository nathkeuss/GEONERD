{% extends 'admin/base.html.twig' %}

{% block title %}Modifier le pays{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #121212;
            color: #f1f1f1;
        }

        .form-container {
            background-color: #1e1e1e;
            border-radius: 10px;
            padding: 2rem;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

        .form-control, .form-select {
            background-color: #222;
            border: 1px solid #444;
            color: #fff;
        }

        .form-control:focus, .form-select:focus {
            background-color: #333;
            color: #fff;
            border-color: #0d6efd;
            box-shadow: 0 0 5px rgba(13, 110, 253, 0.5);
        }

        .btn-primary {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }

        .btn-primary:hover {
            background-color: #0b5ed7;
            border-color: #0a58ca;
        }

        img {
            max-height: 150px;
            border-radius: 8px;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="container py-5">
        <h1 class="text-center mb-4">Modifier le pays</h1>
        <div class="form-container mx-auto">

            <div class="mb-4 text-center">
                <p class="mb-2 fs-3">Drapeau actuel :</p>
                <img src="{{ asset('assets/img_uploads/img_flags/' ~ currentFlag) }}" alt="Drapeau du pays {{ country.name }}" class="img-fluid">
            </div>

            {{ form_start(formCountryView) }}

            <div class="mb-3">
                {{ form_label(formCountryView.name) }}
                {{ form_widget(formCountryView.name) }}
                {{ form_errors(formCountryView.name) }}
            </div>

            <div class="mb-3">
                {{ form_label(formCountryView.flag) }}
                {{ form_widget(formCountryView.flag) }}
                {{ form_errors(formCountryView.flag) }}
            </div>

            <div class="mb-3">
                {{ form_label(formCountryView.continent) }}
                {{ form_widget(formCountryView.continent) }}
                {{ form_errors(formCountryView.continent) }}
            </div>

            <div class="text-center">
                {{ form_widget(formCountryView.Valider) }}
            </div>

            {{ form_end(formCountryView) }}

        </div>
    </main>
{% endblock %}
