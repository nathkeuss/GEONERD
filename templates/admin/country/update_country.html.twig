{% extends 'admin/base.html.twig' %}

{% block title %}Modifier le pays{% endblock %}

{% block stylesheets %}

{% endblock %}


{% block body %}

    <div>
        <p>Drapeau actuel :</p>
        <img src="{{ asset('assets/img_uploads/img_flags/' ~ currentFlag) }}" alt="Drapeau du pays {{ country.name }}" style="max-height: 150px;">
    </div>

    {{ form_start(formCountryView) }}

    <div>
        {{ form_label(formCountryView.name, 'Nom du pays') }}
        {{ form_widget(formCountryView.name) }}
        {{ form_errors(formCountryView.name) }}
    </div>

    <div>
        {{ form_label(formCountryView.flag, 'Drapeau du pays') }}
        {{ form_widget(formCountryView.flag) }}
        {{ form_errors(formCountryView.flag) }}
    </div>

    <div>
        {{ form_label(formCountryView.continent, 'Continent associé') }}
        {{ form_widget(formCountryView.continent) }}
        {{ form_errors(formCountryView.continent) }}
    </div>

    <div>
        {{ form_widget(formCountryView.Valider) }}
    </div>

    {{ form_end(formCountryView) }}

{% endblock %}

