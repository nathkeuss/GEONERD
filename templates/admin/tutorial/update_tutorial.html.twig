{% extends 'admin/base.html.twig' %}

{% block title %}Modifier le tutoriel{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #121212;
            color: #f1f1f1;
        }
        .form-label {
            color: #f1f1f1;
        }
        .form-control, .form-select {
            background-color: #1e1e1e;
            color: #fff;
            border: 1px solid #444;
        }
        .form-control:focus, .form-select:focus {
            background-color: #333;
            border-color: #0d6efd;
            box-shadow: 0 0 5px rgba(13, 110, 253, 0.5);
        }
        .btn-primary {
            background-color: #0d6efd;
            border-color: #0d6efd;
        }
        .btn-primary:hover {
            background-color: #0b5ed7;
            border-color: #0a58ca;
        }
        img {
            max-height: 150px;
            border-radius: 8px;
            margin-bottom: 1rem;
        }
    </style>
{% endblock %}

{% block body %}
    <main class="container py-5">

        <div class="w-100 m-auto">
            <div class="w-75 h-100 m-auto text-center">
                <h3 class="text-center mb-4">Image du pays actuelle :</h3>
                <div class="w-100 h-100">
                    <img src="{{ asset('assets/img_uploads/img_tutorials/' ~ currentImage) }}" alt="Image du tutoriel {{ tutorial.title }}">
                </div>
            </div>

            <div class="w-75 h-100 m-auto text-center">
                <h3 class="text-center mb-4">Image de fond actuelle</h3>
                <div class="w-100 h-100">
                    <img src="{{ asset('assets/img_uploads/img_tutorials/' ~ currentBackgroundImage) }}" alt="Image de fond du tutoriel {{ tutorial.title }}" class="img-fluid">
                </div>
            </div>
        </div>


        {{ form_start(formTutorialView) }}

        <div class="mb-3">
            {{ form_label(formTutorialView.image) }}
            {{ form_widget(formTutorialView.image) }}
            {{ form_errors(formTutorialView.image) }}
        </div>

        <div class="mb-3">
            {{ form_label(formTutorialView.backgroundImage) }}
            {{ form_widget(formTutorialView.backgroundImage) }}
            {{ form_errors(formTutorialView.backgroundImage) }}
        </div>

        <div class="mb-3">
            {{ form_label(formTutorialView.title) }}
            {{ form_widget(formTutorialView.title) }}
            {{ form_errors(formTutorialView.title) }}
        </div>

        <div class="mb-3">
            {{ form_label(formTutorialView.country) }}
            {{ form_widget(formTutorialView.country) }}
            {{ form_errors(formTutorialView.country) }}
        </div>

        <div class="mt-4 text-center">
            {{ form_widget(formTutorialView.Valider) }}
        </div>

        {{ form_end(formTutorialView) }}

    </main>
{% endblock %}
